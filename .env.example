# Logging ---------------------------------------------------------
# INFO, DEBUG, WARNING, ERROR
AUTO_UFL_LOG_LEVEL=INFO
# Whether to print logs to stdout (true/false)
AUTO_UFL_LOG_CONSOLE=true
# Optional log file (set to an absolute path to enable file logging)
AUTO_UFL_LOG_PATH=

# Excel processing -----------------------------------------------
# Sheet name to read (default is 'P&B')
AUTO_UFL_SHEET_NAME=P&B

# Default input/output folders used by --auto mode
AUTO_UFL_INPUT_DIR=C:\Users\hirap\Work\cerebulb\projects\AutoUFL\data\incoming
AUTO_UFL_OUTPUT_DIR=C:\Users\hirap\Work\cerebulb\projects\AutoUFL\data\normalized

# Watchdog tuning -------------------------------------------------
# Seconds between polling loops while watching folders
AUTO_UFL_WATCH_INTERVAL=1.0
# Seconds to wait for a file size to stabilize before processing
AUTO_UFL_FILE_STABILIZE=1.0
