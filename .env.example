# Logging ---------------------------------------------------------
# Valid levels: TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
AUTO_UFL_LOG_LEVEL=INFO

# Accepted values: true/false/1/0/yes/no (case-insensitive)
AUTO_UFL_LOG_CONSOLE=true

# Absolute path for the rolling log file sink
AUTO_UFL_LOG_PATH=C:\Users\hirap\Work\cerebulb\6_UFL\AutoUFL\autoUFL.log

# Loguru-compatible rotation / retention expressions
# Examples: "50 MB", "1 week", "10 files"
AUTO_UFL_LOG_ROTATION=5 MB
AUTO_UFL_LOG_RETENTION=0

# Processing defaults ---------------------------------------------
# Time of day appended to normalized month-start timestamps
AUTO_UFL_DEFAULT_TIMESTAMP=05:00:00

# Override the default input/output folders used by the watcher
AUTO_UFL_INPUT_DIR=C:\Users\hirap\Work\cerebulb\6_UFL\AutoUFL\Client Input
AUTO_UFL_OUTPUT_DIR=C:\Users\hirap\Work\cerebulb\6_UFL\AutoUFL\CSV UFL Input

# Watchdog tuning -------------------------------------------------
# Seconds between observer polling loops
AUTO_UFL_WATCH_INTERVAL=1.0
# Seconds to wait for a file to stop growing before processing
AUTO_UFL_FILE_STABILIZE=1.0

# Client selection ------------------------------------------------
# Forces a default client when --client is omitted.
# Leave blank to fall back to the first discovered client.
AUTO_UFL_CLIENT_ENV=
